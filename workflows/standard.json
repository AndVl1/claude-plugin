{
  "name": "standard",
  "title": "Standard Feature Development",
  "description": "MEDIUM features. Single architect (no parallel options), still clarifies and reviews.",
  "match": { "type": ["FEATURE", "REFACTOR", "OPS"], "complexity": ["MEDIUM", "COMPLEX"] },
  "stages": [
    {
      "id": "discovery",
      "title": "Discovery",
      "type": "orchestrator",
      "gate": "branch_created",
      "checkpoint": "confirm_understanding",
      "autonomous": "log confirmed understanding, continue",
      "produces": "discovery"
    },
    {
      "id": "exploration",
      "title": "Codebase Exploration",
      "type": "consilium",
      "roles": ["analyst", "tech-researcher"],
      "parallel": true,
      "consumes": ["discovery"],
      "produces": ["exploration", "dod"]
    },
    {
      "id": "clarify",
      "title": "Clarifying Questions",
      "type": "orchestrator",
      "consumes": ["discovery", "exploration"],
      "checkpoint": "user_answers",
      "autonomous": "abort needs-human if confidence LOW; else resolve with documented defaults",
      "produces": "clarifications"
    },
    {
      "id": "architecture",
      "title": "Architecture Design (single)",
      "type": "single",
      "role": "architect",
      "consumes": ["exploration", "clarifications"],
      "checkpoint": "user_choice",
      "autonomous": "proceed with proposed design",
      "produces": "architecture"
    },
    {
      "id": "implementation",
      "title": "Implementation",
      "type": "single",
      "role": "${scope.dev_agent}",
      "consumes": ["architecture", "exploration"],
      "checkpoint": "approve_implementation",
      "autonomous": "proceed",
      "produces": "implementation"
    },
    {
      "id": "code_review",
      "title": "Code Review",
      "type": "consilium",
      "roles": ["code-reviewer"],
      "parallel": true,
      "conditional": [
        { "if": "scope.has_security", "add": "security-tester" },
        { "if": "scope.has_infra", "add": "devops" }
      ],
      "consumes": ["implementation", "architecture"],
      "gate": "verdict != reject",
      "checkpoint": "fix_decision",
      "autonomous": "fix CRITICAL+HIGH, then continue",
      "produces": "review"
    },
    {
      "id": "review_fixes",
      "title": "Review Fixes",
      "type": "single",
      "role": "${scope.dev_agent}",
      "consumes": ["review"],
      "checkpoint": "fix_selection",
      "autonomous": "fix CRITICAL+HIGH, defer the rest",
      "skip_if": "review.findings == []"
    },
    {
      "id": "manual_qa",
      "title": "Manual QA (fixed code)",
      "type": "single",
      "role": "manual-qa",
      "consumes": ["review", "implementation", "architecture"],
      "skip_if": "!scope.has_ui",
      "gate": "manual_qa.verdict != FAIL",
      "produces": "manual_qa"
    },
    {
      "id": "qa_tests",
      "title": "Automated Tests",
      "type": "single",
      "role": "qa",
      "consumes": ["manual_qa", "implementation", "architecture"],
      "gate": "manual_qa.verdict == PASS || !scope.has_ui",
      "produces": "qa_tests"
    },
    {
      "id": "summary",
      "title": "Summary",
      "type": "orchestrator",
      "consumes": ["implementation", "review", "manual_qa", "qa_tests", "dod"],
      "gate": "dod_complete",
      "produces": "summary"
    }
  ]
}
