{
  "name": "debug-cycle",
  "title": "Debug Cycle (diagnostics ↔ manual-qa loop)",
  "description": "BUG_FIX requiring verification, or any BUG_FIX in autonomous mode. Iterative loop: diagnose → fix → manual-qa verify; on FAIL loop back to diagnose with new evidence (max 3).",
  "match": { "type": ["BUG_FIX"], "complexity": ["MEDIUM", "COMPLEX", "CRITICAL"] },
  "stages": [
    {
      "id": "discovery",
      "title": "Discovery",
      "type": "orchestrator",
      "gate": "branch_created",
      "produces": "discovery"
    },
    {
      "id": "diagnose",
      "title": "Diagnostics",
      "type": "single",
      "role": "diagnostics",
      "consumes": ["discovery", "debug"],
      "gate": "root_cause_documented",
      "produces": ["diagnosis", "dod"]
    },
    {
      "id": "implementation",
      "title": "Apply Fix",
      "type": "single",
      "role": "${scope.dev_agent}",
      "consumes": ["diagnosis"],
      "gate": "root_cause_documented",
      "checkpoint": "approve_fix",
      "autonomous": "proceed",
      "produces": "implementation"
    },
    {
      "id": "verify",
      "title": "Manual QA Verify",
      "type": "single",
      "role": "manual-qa",
      "consumes": ["diagnosis", "implementation"],
      "produces": "debug",
      "loop": {
        "back_to": "diagnose",
        "until": "verdict == PASS",
        "max_iterations": 3,
        "on_exhausted": "escalate_user"
      }
    },
    {
      "id": "qa_tests",
      "title": "Automated Tests",
      "type": "single",
      "role": "qa",
      "consumes": ["debug", "implementation", "diagnosis"],
      "gate": "verdict == PASS",
      "produces": "qa_tests"
    },
    {
      "id": "summary",
      "title": "Summary",
      "type": "orchestrator",
      "consumes": ["implementation", "diagnosis", "debug", "qa_tests", "dod"],
      "gate": "dod_complete",
      "produces": "summary"
    }
  ]
}
