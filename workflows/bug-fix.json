{
  "name": "bug-fix",
  "title": "Quick Bug Fix",
  "description": "BUG_FIX with an obvious fix. Diagnostics → fix → review. For bugs needing iterative verification, the interpreter promotes to the debug-cycle profile (autonomous mode always uses debug-cycle).",
  "match": { "type": ["BUG_FIX"] },
  "stages": [
    {
      "id": "discovery",
      "title": "Discovery",
      "type": "orchestrator",
      "gate": "branch_created",
      "produces": "discovery"
    },
    {
      "id": "diagnose",
      "title": "Diagnostics",
      "type": "single",
      "role": "diagnostics",
      "consumes": ["discovery"],
      "produces": "diagnosis"
    },
    {
      "id": "implementation",
      "title": "Apply Fix",
      "type": "single",
      "role": "${scope.dev_agent}",
      "consumes": ["diagnosis"],
      "checkpoint": "approve_fix",
      "autonomous": "proceed",
      "produces": "implementation"
    },
    {
      "id": "review",
      "title": "Verify Fix",
      "type": "single",
      "role": "qa",
      "consumes": ["implementation", "diagnosis"],
      "gate": "confidence>=80",
      "produces": "review"
    },
    {
      "id": "summary",
      "title": "Summary",
      "type": "orchestrator",
      "consumes": ["implementation", "diagnosis", "review"],
      "produces": "summary"
    }
  ]
}
